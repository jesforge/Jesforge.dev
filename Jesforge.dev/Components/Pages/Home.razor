@page "/about"
@page "/"

@using Microsoft.AspNetCore.Components

<main class="min-h-screen bg-[#121212] text-white">
    <header class="w-full py-6 px-4 flex justify-between items-center bg-gray-800 shadow-lg">
        <h1 class="text-2xl font-bold mb-9">
            <img
                src="img/jesforge.png"
                class="inline-flex"
                width="70"
                height="70"
            />
            Jesforge
        </h1>
        <nav class="flex space-x-4">
            <a href="#projects" class="px-4 py-2 text-gray-300 hover:text-white flex items-center space-x-2">
                <i class="icon-package" style="margin-right: 4px;"></i>
                <span>Projects</span>
            </a>
            <a href="#skills" class="px-4 py-2 text-gray-300 hover:text-white flex items-center space-x-2">
                <i class="icon-quote" style="margin-right: 4px;"></i>
                <span>Skills</span>
            </a>
            <a href="#contact" class="px-4 py-2 text-gray-300 hover:text-white flex items-center space-x-2">
                <i class="icon-mail" style="margin-right: 4px;"></i>
                <span>Contact</span>
            </a>
        </nav>

    </header>

    <section class="text-center py-20">
        <h2 class="text-4xl font-bold">Hallo, ich bin Jesper!</h2>
        <p class="text-white mt-4">Ich entwickle moderne und effiziente Softwarelösungen.</p>
    </section>

    <section id="projects" class="py-16 px-6">
        <h2 class="text-3xl font-bold text-center mb-8">Projekte</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
                <h3 class="text-xl font-semibold">Projekt 1</h3>
                <p class="text-gray-400">Beschreibung des Projekts.</p>
            </div>
            <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
                <h3 class="text-xl font-semibold">Projekt 2</h3>
                <p class="text-gray-400">Beschreibung des Projekts.</p>
            </div>
        </div>
    </section>
    <section id="skills" class="py-16 px-6">
        <h2 class="text-3xl font-bold text-center mb-8">Programmiersprachen</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            @foreach (var language in Languages)
            {
                <div class="bg-gray-800 p-6 rounded-lg shadow-lg flex items-center justify-center">
                    <img src="@language.Url" alt="@language.Name" class="h-12 w-12 mr-4">
                    <span class="text-lg font-semibold">@language.Name</span>
                </div>
            }
        </div>
    </section>
    <section id="languages" class="py-16 px-6">
        <h2 class="text-3xl font-bold text-center mb-8">TechStack</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            @foreach (var tech in TechStack)
            {
                <div class="bg-gray-800 p-6 rounded-lg shadow-lg flex items-center justify-center">
                    <img src="@tech.Url" alt="@tech.Name" class="h-12 w-12 mr-4">
                    <span class="text-lg font-semibold">@tech.Name</span>
                </div>
            }
        </div>
    </section>
    <section id="contact" class="py-16 bg-gray-800 text-center">
        <h2 class="text-3xl font-bold"><i class="icon-mail inline-flex justify-center items-center"></i> Contact</h2>
        <p class="text-gray-400 mt-2">Contact me with <a href="mailto:me@jesforge.dev" class="text-blue-400">me@jesforge.dev</a>
        </p>
    </section>
</main>

